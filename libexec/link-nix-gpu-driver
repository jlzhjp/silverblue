#!/usr/bin/env bash
set -euo pipefail

shopt -s nullglob

driver_libs=(/nix/store/*-non-nixos-gpu/lib/*.so)

if [[ "${#driver_libs[@]}" -eq 0 ]]; then
	echo "No Nix GPU driver libraries found under /nix/store." >&2
	exit 1
fi

driver_path="${driver_libs[0]%%/lib/*}"

ln -nsfT "${driver_path}" /run/opengl-driver
